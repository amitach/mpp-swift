.build/
.swiftpm/
Package.resolved
*.xcodeproj
DerivedData/
.DS_Store
*.swiftmodule
.netrc

# Conformance harness (dev-only Node tooling). The lockfile IS committed so CI
# uses `npm ci` for reproducible, pinned installs; only the install tree is ignored.
Scripts/conformance/node_modules/

# Rust FFI build artifacts (Cargo.lock IS committed for a reproducible, auditable build)
rust/*/target/

# The TempoTxFFI xcframework is BUILT IN CI from pinned tempo-primitives source
# (provenance, no committed binary blob); build-xcframework.sh produces it locally.
# The generated Swift bindings under Sources/MPPTempoFFI/Generated ARE committed and
# drift-checked in CI, so they are deliberately not ignored.
artifacts/
