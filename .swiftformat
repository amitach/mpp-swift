# swiftformat configuration for mpp-swift
--swiftversion 6.0
--indent 4
--maxwidth 100
--wraparguments before-first
--wrapparameters before-first
--wrapcollections before-first
--self remove
--importgrouping testable-bottom
--trimwhitespace always
# trailingCommas is owned by swiftlint (mandatory_comma); docComments is too
# aggressive for file-header comments. Disable both here to avoid tool conflicts.
--disable redundantReturn,trailingCommas,docComments
